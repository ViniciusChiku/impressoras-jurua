# Credenciais do Firebase (Públicas)
REACT_APP_FIREBASE_API_KEY=insira_sua_api_key_do_firebase_aqui
REACT_APP_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=seu_projeto_id
REACT_APP_FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=seu_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=seu_measurement_id

# Configurações de Acesso Administrativo
REACT_APP_ADMIN_EMAIL=seu_email_admin@exemplo.com

# Chave Privada do Google Gemini (SEGREDO - NUNCA EXPOR OU COMPARTILHAR!)
REACT_APP_GEMINI_API_KEY=insira_sua_chave_do_google_ai_studio_aqui

# Configurações de Compilação
GENERATE_SOURCEMAP=false
