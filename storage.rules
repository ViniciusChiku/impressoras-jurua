rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Regra de segurança para a pasta de imagens dos contadores das impressoras
    match /printers_counters/{imageId} {
      
      // Permitir leitura das fotos para qualquer usuário autenticado (incluindo convidados)
      allow read: if request.auth != null;
      
      // Permitir upload e exclusão de fotos de contadores apenas para o e-mail administrador
      allow write: if request.auth != null 
        && request.auth.token.email == 'vini.chiku123@gmail.com'
        && request.resource.size < 5 * 1024 * 1024 // Limita arquivos a 5MB
        && request.resource.contentType.matches('image/.*'); // Permite apenas imagens
    }
  }
}
