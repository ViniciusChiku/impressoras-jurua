rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra de segurança para a coleção de impressoras no Mapa Juruá
    match /artifacts/{appId}/public/data/printers/{printerId} {
      
      // Permitir leitura para qualquer usuário autenticado (incluindo acessos anônimos/convidados)
      allow read: if request.auth != null;
      
      // Permitir gravação, atualização e exclusão apenas para o e-mail administrador cadastrado
      allow write: if request.auth != null && (
        request.auth.token.email == 'vini.chiku123@gmail.com'
      );
    }

    // Regra de segurança para a coleção de quests (missões de contadores) no Mapa Juruá
    match /artifacts/{appId}/public/data/quests/{questId} {
      
      // Permitir leitura para qualquer usuário autenticado
      allow read: if request.auth != null;
      
      // Permitir gravação apenas para o e-mail administrador cadastrado
      allow write: if request.auth != null && (
        request.auth.token.email == 'vini.chiku123@gmail.com'
      );
    }
  }
}
